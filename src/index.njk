---
layout: base.njk
title: Scuba Diving and Snorkelling Club
---

<!-- Hero Section -->
<section class="hero" id="home">
    <div class="hero-overlay"></div>
    <div class="hero-content container">
        <h1>Mid Herts Divers</h1>
        <p class="hero-subtitle">Scuba Diving and Snorkelling Club</p>
        <p class="hero-description">We are British Sub Aqua Club branch 1784, based at the Hatfield Swim Centre. We welcome both trainee and experienced divers and snorkellers. Come dive with us!</p>
    </div>
</section>

<!-- Feature Cards -->
<section class="features container">
    <div class="feature-card">
        <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <h3>New to Diving?</h3>
        <p>If you are new to scuba diving and want to learn you are in the right place! Learning to scuba dive can be a life-changing experience, bringing a whole host of exciting underwater opportunities your way.</p>
        <a href="/new-diver/" class="feature-link">Learn to dive &raquo;</a>
    </div>
    <div class="feature-card">
        <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3>Already a Diver?</h3>
        <p>Are you a qualified scuba diver with PADI, SSI, RAID, GUE or another agency? Great! Continue the adventure… join great people in your area on some memory-making scuba diving.</p>
        <a href="/existing-divers/" class="feature-link">Get back in the water &raquo;</a>
    </div>
</section>

<!-- Try Scuba Section -->
<section class="try-scuba" id="try-dive">
    <div class="try-scuba-content container">
        <div class="try-scuba-text">
            <h2>Try Scuba</h2>
            <p>In the safe confines of the pool, one of our friendly BSAC Instructors will introduce you to the basic skills and equipment needed to experience the thrill of breathing underwater for the very first time.</p>
            <a href="/try-dive/" class="btn-primary btn-large">Book Now</a>
        </div>
        <div class="try-scuba-image">
            <div class="placeholder-image">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9a2 2 0 0 1 2-2h.93a2 2 0 0 0 1.664-.89l.812-1.22A2 2 0 0 1 10.07 4h3.86a2 2 0 0 1 1.664.89l.812 1.22A2 2 0 0 0 18.07 7H19a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/><circle cx="12" cy="13" r="3"/></svg>
                <span>Try Scuba Experience</span>
            </div>
        </div>
    </div>
</section>

<!-- Recent Articles -->
<section class="articles" id="articles">
    <div class="container">
        <div class="section-header">
            <h2>Recent Articles</h2>
            <a href="/articles/" class="see-all">See all &raquo;</a>
        </div>
        <div class="articles-grid">
            {% for article in collections.articles | reverse %}
            {% if loop.index <= 3 %}
            <article class="article-card">
                <div class="article-image">
                    {% if article.data.image %}
                    <img src="{{ article.data.image }}" alt="{{ article.data.title }}" loading="lazy">
                    {% else %}
                    <div class="placeholder-image" style="height:200px;border-radius:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                    {% endif %}
                </div>
                <div class="article-content">
                    <h3><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
                    <p>{{ article.data.excerpt }}</p>
                    <div class="article-meta">
                        <span class="author">{{ article.data.author }}</span>
                        <span class="date">{{ article.date | dateFormat }}</span>
                    </div>
                </div>
            </article>
            {% endif %}
            {% endfor %}
        </div>
    </div>
</section>

<!-- Membership Benefits -->
<section class="membership" id="membership">
    <div class="container">
        <h2>What's included in the Membership?</h2>
        <div class="benefits-grid">
            <div class="benefit-item">
                <div class="benefit-icon">🏊</div>
                <p>Access to a 33m swimming pool with depth to 3.8m</p>
            </div>
            <div class="benefit-item">
                <div class="benefit-icon">🎓</div>
                <p>Training with Nationally Qualified Instructors to an Internationally recognised standard</p>
            </div>
            <div class="benefit-item">
                <div class="benefit-icon">✈️</div>
                <p>Club trips to UK and Overseas destinations</p>
            </div>
            <div class="benefit-item">
                <div class="benefit-icon">🌊</div>
                <p>Access to local open water facility</p>
            </div>
            <div class="benefit-item">
                <div class="benefit-icon">🤿</div>
                <p>Access to club Scuba kit during training</p>
            </div>
            <div class="benefit-item">
                <div class="benefit-icon">💨</div>
                <p>Free Air Fills</p>
            </div>
        </div>
        <a href="/try-dive/" class="btn-primary btn-large">Join Now</a>
    </div>
</section>

<!-- Instagram Gallery -->
<section class="gallery" id="gallery">
    <div class="container">
        <div class="section-header">
            <h2>Latest Images</h2>
            <a href="https://instagram.com/midhertsdivers" class="see-all" target="_blank" rel="noopener">See all on Instagram &raquo;</a>
        </div>
        <div class="gallery-grid" id="instagramGallery">
            <p class="loading-text">Loading gallery...</p>
        </div>
    </div>
</section>
