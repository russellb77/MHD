---
layout: base.njk
title: Contact Us
permalink: /contact/
---

<section class="page-hero">
    <div class="container">
        <h1>Contact Us</h1>
        <p>Get in touch — we'd love to hear from you</p>
    </div>
</section>

<section class="form-section">
    <div class="container form-layout">
        <div class="form-info">
            <h2>Get in Touch</h2>
            <p>Whether you have a question about joining, want to find out about our training, or just fancy a chat about diving — drop us a message.</p>
            
            <h3>Other Ways to Reach Us</h3>
            <ul class="info-list">
                <li>📧 <a href="mailto:hello@midhertsdivers.com">hello@midhertsdivers.com</a></li>
                <li>📍 Hatfield Swim Centre, Hertfordshire</li>
                <li>🕗 Pool nights: Thursdays 8-9:30pm</li>
            </ul>

            <h3>Follow Us</h3>
            <ul class="info-list">
                <li>📘 <a href="https://facebook.com/midhertsdivers" target="_blank" rel="noopener">Facebook</a></li>
                <li>📷 <a href="https://instagram.com/midhertsdivers" target="_blank" rel="noopener">Instagram</a></li>
            </ul>
        </div>

        <div class="form-container">
            <h2>Send Us a Message</h2>
            <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
                <p class="hidden">
                    <label>Don't fill this out: <input name="bot-field"></label>
                </p>

                <div class="form-group">
                    <label for="name">Full Name *</label>
                    <input type="text" id="name" name="name" required>
                </div>

                <div class="form-group">
                    <label for="email">Email Address *</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div class="form-group">
                    <label for="subject">Subject</label>
                    <select id="subject" name="subject">
                        <option value="general">General enquiry</option>
                        <option value="joining">Joining the club</option>
                        <option value="try-dive">Try dive question</option>
                        <option value="trips">Trips and events</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="message">Your Message *</label>
                    <textarea id="message" name="message" rows="6" required></textarea>
                </div>

                <button type="submit" class="btn-primary btn-large btn-full">Send Message</button>
            </form>
        </div>
    </div>
</section>
