<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Mid Herts Divers</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Cookie Banner -->
    <div class="cookie-banner" id="cookieBanner">
        <p>This website uses cookies to ensure you get the best experience on our website. <a href="/privacy/">More info</a></p>
        <button class="btn-cookie" onclick="document.getElementById('cookieBanner').style.display='none'">Got it!</button>
    </div>

    <!-- Navigation -->
    <header class="header">
        <nav class="nav container">
            <a href="/" class="logo">Mid Herts Divers</a>
            <ul class="nav-links" id="navLinks">
                <li><a href="/">Home</a></li>
                <li><a href="/articles/">Articles</a></li>
                <li><a href="/gallery/">Gallery</a></li>
                <li><a href="/about/">About</a></li>
                <li><a href="/contact/">Contact</a></li>
            </ul>
            <div class="nav-actions">
                <a href="/admin/" class="btn-signin">Sign in</a>
                <a href="/try-dive/" class="btn-primary">Book a try dive</a>
            </div>
            <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
    </header>

    {{ content | safe }}

    <!-- Footer -->
    <footer class="footer">
        <div class="container footer-content">
            <div class="footer-section">
                <h4>Website</h4>
                <ul>
                    <li><a href="/privacy/">Privacy Policy</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>About Us</h4>
                <ul>
                    <li><a href="https://www.bsac.com/document/bsac-equality-diversity-and-inclusion-policy/bsac-equality-diversity-and-inclusion-2021.pdf" target="_blank" rel="noopener">Diversity and inclusivity policy</a></li>
                    <li><a href="https://www.bsac.com/this-is-bsac/bsac-rules-and-policies/safeguarding-policy/" target="_blank" rel="noopener">Safeguarding policy</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="https://facebook.com/midhertsdivers" aria-label="Facebook" class="social-link" target="_blank" rel="noopener">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                    </a>
                    <a href="https://instagram.com/midhertsdivers" aria-label="Instagram" class="social-link" target="_blank" rel="noopener">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                    </a>
                </div>
            </div>
        </div>
        <div class="footer-bottom container">
            <p>&copy; 2026 Mid Herts Divers</p>
        </div>
    </footer>

    <script src="/script.js"></script>
</body>
</html>
