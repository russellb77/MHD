---
layout: base.njk
---

<section class="page-hero">
    <div class="container">
        <h1>{{ title }}</h1>
        <p>By {{ author }} &bull; {{ date | dateFormat }}</p>
    </div>
</section>

<section class="form-section">
    <div class="container" style="max-width:800px;">
        <div class="about-content article-body">
            {% if image %}
            <img src="{{ image }}" alt="{{ title }}" style="width:100%; border-radius:12px; margin-bottom:32px;">
            {% endif %}
            {{ content | safe }}
        </div>
        <div style="margin-top:48px; padding-top:24px; border-top:1px solid #eee;">
            <a href="/articles/" style="color:var(--primary); font-weight:600;">&laquo; Back to all articles</a>
        </div>
    </div>
</section>
