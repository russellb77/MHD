---
layout: base.njk
title: Gallery
permalink: /gallery/
---

<section class="page-hero">
    <div class="container">
        <h1>Gallery</h1>
        <p>Photos from our dives and adventures</p>
    </div>
</section>

<section class="gallery">
    <div class="container">
        <div class="gallery-grid">
            {% for item in collections.galleryImages %}
            <div class="gallery-item">
                <img src="{{ item.data.image }}" alt="{{ item.data.caption }}" loading="lazy">
                <p class="gallery-caption">{{ item.data.caption }}</p>
            </div>
            {% endfor %}
        </div>
        <div style="text-align:center; margin-top:40px;">
            <a href="https://instagram.com/midhertsdivers" class="btn-primary btn-large" target="_blank" rel="noopener">Follow us on Instagram</a>
        </div>
    </div>
</section>
